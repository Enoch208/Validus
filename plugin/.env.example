# Validus plugin environment variables
#
# Copy this file to .env and fill in only what you need.
# The plugin works with ZERO env vars set — defaults are sensible.
# Add a var only when you hit the case that needs it.
#
# Loading: this .env file is NOT auto-loaded by the plugin or by Franklin.
# Set these in your shell, in your systemd unit (see server/validus.service),
# or via direnv / dotenv-cli. For systemd: add `Environment=KEY=value` lines.

# ──────────────────────────────────────────────────────────────────────
# Comfort — totally optional
# ──────────────────────────────────────────────────────────────────────

# Free GitHub token, read-only public repo scope. Bumps API rate limit
# from 60/hr to 5,000/hr. Recommended even for dev.
# Generate: https://github.com/settings/tokens?type=beta
# GITHUB_TOKEN=

# Set to 1 to force every workflow step that would call the cheap or premium
# tier to fall back to free. Useful before funding the Franklin wallet for
# x402 cheap/premium spend.
# VALIDUS_FREE_ONLY=1

# Override the workflow config's prUrl without rewriting the config file.
# Handy for one-off CLI runs: VALIDUS_PR_URL=... franklin validus run --dry
# VALIDUS_PR_URL=

# Override where receipt JSON is written.
# Default: ~/.blockrun/validus/receipts/
# Useful when the dashboard reads from a different directory (Vercel, hosted).
# VALIDUS_RECEIPTS_DIR=

# ──────────────────────────────────────────────────────────────────────
# Real payouts — required only when mode is testnet or mainnet
# ──────────────────────────────────────────────────────────────────────

# One of: dry-run | testnet | mainnet
# Default: dry-run (no chain interaction, just logs the payload)
# PAYOUT_MODE=dry-run

# Wallet that signs USDC.transfer. Hex-encoded, with or without 0x prefix.
# REQUIRED if PAYOUT_MODE is testnet or mainnet. NEVER commit this.
# Generate a fresh wallet: `cast wallet new` (foundry) or via any wallet UI.
# Fund Base Sepolia from https://faucet.circle.com (USDC) +
# https://www.alchemy.com/faucets/base-sepolia (ETH for gas).
# PAYOUT_PRIVATE_KEY=

# ──────────────────────────────────────────────────────────────────────
# HTTP server — required only when running plugin/server/index.mjs
# ──────────────────────────────────────────────────────────────────────

# Listen port (default 4000)
# PORT=4000

# Optional shared secret. If set, all /review requests must include
# Authorization: Bearer <token>. Generate with: openssl rand -hex 32
# Recommended for production. Without it the endpoint is open to anyone.
# VALIDUS_AUTH_TOKEN=

# CORS Access-Control-Allow-Origin.
# Default: *  (open — fine for dev, tighten for production)
# Set to your Vercel deployment URL in production.
# ALLOWED_ORIGIN=https://validus.yourdomain.com
